<Window x:Class="PianoFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PianoFlow" 
        Width="1920" Height="1080"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF0A0E1A"
        KeyDown="Window_KeyDown"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Grid x:Name="RootGrid">
        <!-- PianoFlowVisual will be added programmatically -->

        <!-- Welcome overlay -->
        <Border x:Name="WelcomeOverlay"
                Background="#CC0A0E1A"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="12" Padding="48,32">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🎹" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="PianoFlow" Foreground="#4FC3F7" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="MIDI Piano Visualizer" Foreground="#666" FontSize="14"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <TextBlock Foreground="#888" FontSize="13" HorizontalAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="400">
                    Press O to open a MIDI file, or drag &amp; drop a .mid file here.
                </TextBlock>
                <TextBlock Foreground="#555" FontSize="12" HorizontalAlignment="Center" Margin="0,16,0,0">
                    F1 — Toggle controls
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Top-right buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12">
            <Button x:Name="SettingsButton" Content="⚙" FontSize="18"
                    Width="36" Height="36"
                    Background="#33FFFFFF" Foreground="#AAA"
                    BorderThickness="0" Cursor="Hand"
                    Click="SettingsButton_Click"
                    Margin="0,0,4,0"/>
            <Button Content="✕" FontSize="16"
                    Width="36" Height="36"
                    Background="#33FFFFFF" Foreground="#AAA"
                    BorderThickness="0" Cursor="Hand"
                    Click="CloseButton_Click"/>
        </StackPanel>

        <!-- Bottom status bar (F1 toggle) -->
        <Border x:Name="StatusBar" 
                Background="#EE111525"
                VerticalAlignment="Bottom" 
                Height="40"
                CornerRadius="6"
                Margin="8"
                Opacity="0"
                Visibility="Collapsed">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="PlayStateText" Grid.Column="0"
                           Text="⏹ Stopped" Foreground="#888" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="TimeText" Grid.Column="1"
                           Text="0:00 / 0:00" Foreground="#AAA" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="MidiDeviceText" Grid.Column="2"
                           Text="" Foreground="#666" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="StatusText" Grid.Column="3"
                           Text="" Foreground="#555" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="4"
                           Text="Space ▶⏸  R ↻  F ↕  ↑↓ Speed  E Export  O Open  F1 UI  Q Quit"
                           Foreground="#444" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Settings panel -->
        <Border x:Name="SettingsPanel"
                Background="#EE111525"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Width="320"
                CornerRadius="8,0,0,8"
                Margin="0,8,0,8"
                Opacity="0"
                Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16">
                    <TextBlock Text="⚙ Settings" Foreground="#4FC3F7" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="MIDI Input Device" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox x:Name="MidiDeviceCombo" Height="30" FontSize="12"
                              Background="#222" Foreground="#EEE" BorderBrush="#333"
                              SelectionChanged="MidiDeviceCombo_Changed"/>
                    <Separator Background="#222" Margin="0,12,0,12"/>

                    <TextBlock Text="Note Speed" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <Slider x:Name="SpeedSlider" Minimum="50" Maximum="1000" Value="300"
                            ValueChanged="SpeedSlider_Changed"/>
                    <TextBlock x:Name="SpeedLabel" Text="300 px/s" Foreground="#666" FontSize="11"
                               HorizontalAlignment="Right" Margin="0,0,0,8"/>
                    <Separator Background="#222" Margin="0,4,0,12"/>

                    <TextBlock Text="Note Direction" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="DirFalling" Content="↓ Falling" Foreground="#AAA"
                                     IsChecked="True" GroupName="Direction"
                                     Checked="Direction_Changed" Margin="0,0,16,0"/>
                        <RadioButton x:Name="DirRising" Content="↑ Rising" Foreground="#AAA"
                                     GroupName="Direction"
                                     Checked="Direction_Changed"/>
                    </StackPanel>
                    <Separator Background="#222" Margin="0,12,0,12"/>

                    <TextBlock Text="Piano Height %" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <Slider x:Name="PianoHeightSlider" Minimum="5" Maximum="25" Value="11"
                            ValueChanged="PianoHeightSlider_Changed"/>
                    <TextBlock x:Name="PianoHeightLabel" Text="11%" Foreground="#666" FontSize="11"
                               HorizontalAlignment="Right" Margin="0,0,0,8"/>
                    <Separator Background="#222" Margin="0,4,0,12"/>

                    <TextBlock Text="Window" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Fullscreen" FontSize="11" Padding="12,4"
                                Background="#333" Foreground="#AAA" BorderThickness="0"
                                Click="FullscreenButton_Click" Margin="0,0,8,0"/>
                        <Button Content="Windowed" FontSize="11" Padding="12,4"
                                Background="#333" Foreground="#AAA" BorderThickness="0"
                                Click="WindowedButton_Click"/>
                    </StackPanel>
                    <Separator Background="#222" Margin="0,12,0,12"/>

                    <TextBlock Text="Export FPS" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ExportFpsCombo" Width="80" Height="28" FontSize="12"
                              Background="#222" Foreground="#EEE" BorderBrush="#333">
                        <ComboBoxItem Content="24" IsSelected="False"/>
                        <ComboBoxItem Content="30" IsSelected="True"/>
                        <ComboBoxItem Content="60"/>
                    </ComboBox>
                    <Separator Background="#222" Margin="0,12,0,12"/>

                    <Button Content="Close Settings" FontSize="12" Padding="16,6"
                            Background="#333" Foreground="#AAA" BorderThickness="0"
                            HorizontalAlignment="Right"
                            Click="CloseSettingsButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Export overlay -->
        <Border x:Name="ExportOverlay"
                Background="#AA000000"
                Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="8" Padding="24,16">
            <StackPanel>
                <TextBlock Text="Exporting Video..." Foreground="White" FontSize="16"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <ProgressBar x:Name="ExportProgress" Width="300" Height="20"
                             Minimum="0" Maximum="100"/>
                <TextBlock x:Name="ExportProgressText" Text="0%"
                           Foreground="#AAA" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
