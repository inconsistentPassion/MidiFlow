<Window x:Class="PianoFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PianoFlow" 
        Width="1920" Height="1080"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF0A0E1A"
        KeyDown="Window_KeyDown"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        MouseMove="Window_MouseMove"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Grid>
        <!-- Main rendering canvas -->
        <Image x:Name="RenderImage" Stretch="None" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- Auto-hiding bottom status bar -->
        <Border x:Name="StatusBar" 
                Background="#CC0A0E1A"
                VerticalAlignment="Bottom" 
                Height="36"
                CornerRadius="4"
                Margin="8"
                Opacity="0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Play state -->
                <TextBlock x:Name="PlayStateText" Grid.Column="0"
                           Text="⏸ Paused" Foreground="#888" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- Time -->
                <TextBlock x:Name="TimeText" Grid.Column="1"
                           Text="0:00 / 0:00" Foreground="#AAA" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- MIDI Device -->
                <TextBlock x:Name="MidiDeviceText" Grid.Column="2"
                           Text="" Foreground="#666" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- Status -->
                <TextBlock x:Name="StatusText" Grid.Column="3"
                           Text="" Foreground="#555" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- Controls hint -->
                <TextBlock Grid.Column="4"
                           Text="Space ▶⏸  R ↻  F ↕  ↑↓ Speed  E Export  O Open  Q Quit"
                           Foreground="#444" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Export progress overlay -->
        <Border x:Name="ExportOverlay"
                Background="#AA000000"
                Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="8" Padding="24,16">
            <StackPanel>
                <TextBlock Text="Exporting Video..." Foreground="White" FontSize="16"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <ProgressBar x:Name="ExportProgress" Width="300" Height="20"
                             Minimum="0" Maximum="100"/>
                <TextBlock x:Name="ExportProgressText" Text="0%"
                           Foreground="#AAA" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
